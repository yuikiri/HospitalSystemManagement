<?xml version="1.0" encoding="UTF-8"?>
<web-app version="2.5" xmlns="http://java.sun.com/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://java.sun.com/xml/ns/javaee http://java.sun.com/xml/ns/javaee/web-app_2_5.xsd">
    <!-- MAIN CONTROLLER -->
    <servlet>
        <servlet-name>MainController</servlet-name>
        <servlet-class>controller.MainController</servlet-class>
    </servlet>
    <!-- LOGIN -->
    <servlet>
        <servlet-name>LoginController</servlet-name>
        <servlet-class>controller.LoginController</servlet-class>
    </servlet>
    <!-- REGISTER -->
    <servlet>
        <servlet-name>RegisterController</servlet-name>
        <servlet-class>controller.RegisterController</servlet-class>
    </servlet>
    <!-- LOGOUT -->
    <servlet>
        <servlet-name>LogoutController</servlet-name>
        <servlet-class>controller.LogoutController</servlet-class>
    </servlet>
    <!-- UPDATE PROFILE -->
    <servlet>
        <servlet-name>UpdateProfileController1</servlet-name>
        <servlet-class>controller.UpdateProfileController1</servlet-class>
    </servlet>
    <!-- SERVLET MAPPING -->
    <servlet>
        <servlet-name>AdminUserController</servlet-name>
        <servlet-class>controller.AdminUserController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RequestChangeEmailController</servlet-name>
        <servlet-class>controller.RequestChangeEmailController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RequestChangePasswordController</servlet-name>
        <servlet-class>controller.RequestChangePasswordController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>VerifyEmailController</servlet-name>
        <servlet-class>controller.VerifyEmailController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>VerifyPasswordController</servlet-name>
        <servlet-class>controller.VerifyPasswordController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MainController</servlet-name>
        <url-pattern>/MainController</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LoginController</servlet-name>
        <url-pattern>/LoginController</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RegisterController</servlet-name>
        <url-pattern>/RegisterController</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LogoutController</servlet-name>
        <url-pattern>/LogoutController</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>UpdateProfileController1</servlet-name>
        <url-pattern>/updateProfile</url-pattern>
    </servlet-mapping>
    <!-- SESSION -->
    <servlet-mapping>
        <servlet-name>AdminUserController</servlet-name>
        <url-pattern>/AdminUserController</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RequestChangeEmailController</servlet-name>
        <url-pattern>/RequestChangeEmailController</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RequestChangePasswordController</servlet-name>
        <url-pattern>/RequestChangePasswordController</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>VerifyEmailController</servlet-name>
        <url-pattern>/VerifyEmailController</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>VerifyPasswordController</servlet-name>
        <url-pattern>/VerifyPasswordController</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>
    <!-- HOME PAGE -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
</web-app>
